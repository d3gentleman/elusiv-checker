# Copy to .env.local for local dev (Next.js loads it automatically).
# Free Helius key: https://dashboard.helius.dev → API Keys → Create
# This enables the enhanced API (2–3 requests per wallet check instead of 10+).
HELIUS_API_KEY=your_helius_api_key_here

# Optional: Helius RPC URL also works (api-key in query string is auto-detected)
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here

# Scan more history if Elusiv txs are old (each page = 100 txs, 550ms apart)
# HELIUS_MAX_PAGES=20

# Without Helius, public RPC is very rate-limited — not recommended
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
